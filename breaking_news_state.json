      ],
      "created_at": "2026-06-21T00:03:34.510038+00:00",
      "last_escalated_size": 3,
      "last_escalated_at": "2026-06-21T17:49:43.569930+00:00",
      "picks_file": "picks/picks-2026-06-21-1750.md",
      "why_text": "SZA's intervention lands with particular force because she isn't just defending her own catalog \u2014 she's naming a structural injustice: that platforms like Suno are effectively strip-mining Black musical genius to build products that will compete with and replace the very artists who created that sound. It's a rare moment of a mega-star using their platform to connect IP theft to a racial equity argument, pulling the AI music debate out of the courtroom and into a cultural reckoning. The fact that fellow artists like Kenneth Blume are echoing her publicly signals this could crystallize into a broader industry solidarity movement rather than another isolated complaint.",
      "last_escalated_item_ids": [
        "0c158e213aa8",
        "dc3cf36b58f0",
